{
  "uid": "janus-experiment",
  "title": "Janus Experiment Comparison",
  "tags": ["janus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 10,
      "type": "stat",
      "title": "Availability",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.9},
              {"color": "green", "value": 0.99}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "1 - (sum by (job) (rate(http_server_requests_seconds_count{uri=\"/api/recommendations\",outcome=~\"SERVER_ERROR|CLIENT_ERROR\"}[1m])) / sum by (job) (rate(http_server_requests_seconds_count{uri=\"/api/recommendations\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Quality (with-janus only; without-janus is implicitly 1.0 on success)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.6},
              {"color": "green", "value": 0.9}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(sum by (degradation_id) (rate(janus_degradable_invocations_total{outcome=\"normal\"}[1m])) + sum by (degradation_id) (rate(janus_degradable_invocations_total{outcome=\"fallback\"}[1m])) * 0.5) / sum by (degradation_id) (rate(janus_degradable_invocations_total[1m]))",
          "legendFormat": "{{degradation_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Median client-side latency",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.5, sum by (le, job) (rate(http_server_requests_seconds_bucket{uri=\"/api/recommendations\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "p95 client-side latency",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_server_requests_seconds_bucket{uri=\"/api/recommendations\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPS by client (uri=/api/recommendations)",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{uri=\"/api/recommendations\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 client-side latency",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_server_requests_seconds_bucket{uri=\"/api/recommendations\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Availability (uri=/api/recommendations)",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "1 - (sum by (job) (rate(http_server_requests_seconds_count{uri=\"/api/recommendations\",outcome=~\"SERVER_ERROR|CLIENT_ERROR\"}[1m])) / sum by (job) (rate(http_server_requests_seconds_count{uri=\"/api/recommendations\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "RPS by HTTP status (uri=/api/recommendations)",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (job, status) (rate(http_server_requests_seconds_count{uri=\"/api/recommendations\"}[1m]))",
          "legendFormat": "{{job}} / {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Downstream RPS by outcome (demo-server)",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (job, outcome) (rate(http_client_requests_seconds_count{client_name=\"demo-server\"}[1m]))",
          "legendFormat": "{{job}} / {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p95 downstream latency (demo-server)",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_client_requests_seconds_bucket{client_name=\"demo-server\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Quality (with-janus; min_quality=0.5)",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(sum by (degradation_id) (rate(janus_degradable_invocations_total{outcome=\"normal\"}[1m])) + sum by (degradation_id) (rate(janus_degradable_invocations_total{outcome=\"fallback\"}[1m])) * 0.5) / sum by (degradation_id) (rate(janus_degradable_invocations_total[1m]))",
          "legendFormat": "{{degradation_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Sidecar known degradations",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short", "min": 0},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "janus_sidecar_degradations_active",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "janus_sidecar_degradations_stale",
          "legendFormat": "stale",
          "refId": "B"
        }
      ]
    }
  ]
}
